{
  "name": "cal-tracker",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/backend",
    "packages/contracts"
  ],
  "scripts": {
    "dev:backend": "bun run --cwd apps/backend dev",
    "build": "bun run build:contracts && bun run build:backend",
    "build:backend": "bun run --cwd apps/backend build",
    "build:contracts": "bun run --cwd packages/contracts build",
    "mobile:build:dev": "bash scripts/mobile/build-android.sh dev",
    "mobile:build:prod": "bash scripts/mobile/build-android.sh prod",
    "mobile:build:all": "bash scripts/mobile/build-android.sh all",
    "mobile:release:dev": "bash scripts/mobile/publish-github-release.sh dev",
    "mobile:release:prod": "bash scripts/mobile/publish-github-release.sh prod",
    "typecheck": "bun run --cwd packages/contracts typecheck && bun run build:contracts && bun run --cwd apps/backend typecheck",
    "db:migrate": "bun run --cwd apps/backend db:migrate",
    "db:seed": "bun run --cwd apps/backend db:seed",
    "test": "bun run build:contracts && bun run --cwd apps/backend test",
    "test:backend": "bun run build:contracts && bun run --cwd apps/backend test",
    "generate:openapi": "bun run --cwd packages/contracts generate:openapi",
    "generate:flutter-client": "bun run --cwd apps/backend generate:flutter-client",
    "node:test:backend": "npm --workspace apps/backend run test",
    "node:generate:openapi": "npm --workspace packages/contracts run generate:openapi"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
